name: Build iOS IPA
on:
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: 18

      - name: Install Cordova
        run: npm install -g cordova

      - name: Create Cordova Project
        run: |
          cordova create build_output com.flashgame.app "FlashGame"
          cd build_output
          cordova platform add ios
          rm -rf www/*
          
      - name: Unzip Game Files
        run: |
          unzip flashapp.zip
          cp -R flashapp/* build_output/www/

      - name: Build Xcode Project
        run: |
          cd build_output
          cordova build ios --device --packageType=adhoc
          
      - name: Archive IPA
        run: |
          cd build_output/platforms/ios/build/device/
          mkdir Payload
          mv *.app Payload/
          zip -r FlashGame.ipa Payload
          
      - name: Upload IPA Result
        uses: actions/upload-artifact@v3
        with:
          name: iOS-IPA
          path: build_output/platforms/ios/build/device/FlashGame.ipa
